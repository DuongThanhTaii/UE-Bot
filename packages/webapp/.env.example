# UE-Bot Webapp - Environment Variables for Vercel
# Set these in Vercel Dashboard → Settings → Environment Variables

# Database (Neon PostgreSQL - https://neon.tech)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# JWT Secret (generate: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here

# Groq AI (required for Agent Chat - https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Brave Search API (optional, for web search tool - https://brave.com/search/api/)
BRAVE_SEARCH_API_KEY=

# Bridge Service URL (Render deployment)
NEXT_PUBLIC_API_URL=https://your-bridge-service.onrender.com
NEXT_PUBLIC_WS_URL=wss://your-bridge-service.onrender.com
